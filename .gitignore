# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/

# Secrets — never commit
.env
.env.*
!.env.example

# OS junk
.DS_Store
*.swp
*.swo

# Legacy archives (from the XCO lineage)
archive/
xco-mcp-archive/

# Generated artifact noise
*.zip
generated/*.bak
generated/*.backup

# Runtime state — keep the directory structure but ignore the data.
# `logs/.gitkeep` / `config/.gitkeep` / `snapshots/.gitkeep` are the
# placeholders that make the empty dirs survive in git.
logs/*
!logs/.gitkeep
config/*
!config/.gitkeep
!config/fabric_intent.example.json
!config/inventory.example.json
snapshots/*
!snapshots/.gitkeep

# Smoketest results
smoke-test/*.json
smoke-test/*.txt

# Test / CI cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editor / IDE
.vscode/
.idea/

# Claude / assistant state
.claude/
CLAUDE.md
