# Git + developer metadata — nothing runtime needs
.git/
.gitignore
.github/

# Credentials + lab-specific state — MUST not be baked into the image.
# The docker-compose.yml bind-mounts these from the host.
.env
.env.*
config/
logs/

# Local virtualenv, caches
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Build / CI outputs
*.egg-info/
dist/
build/
.coverage
htmlcov/

# Smoke tests + dev docs stay in the repo but aren't shipped in the image
smoke-test/
docs/
sonic_initial_docs/

# Editor / OS junk
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Intermediate / backup generated artifacts
generated/*.bak
generated/*.backup

# Claude / assistant state
.claude/
CLAUDE.md

# Quarantined legacy code (if still around)
_legacy/
archive/
xco-mcp-archive/
