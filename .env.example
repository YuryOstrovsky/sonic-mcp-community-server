# SONiC MCP Community Server — environment configuration
# Copy to .env and edit values for your lab.

# ------------------------------------------------------------------
# Device credentials
# ------------------------------------------------------------------

# Default credentials applied to all SONiC devices unless overridden per-host.
# The SONiC factory default is admin / YourPaSsWoRd (both sonic-vs and
# hardware). If you have changed the admin password on your switches,
# put the real one here.
SONIC_DEFAULT_USERNAME=admin
SONIC_DEFAULT_PASSWORD=YourPaSsWoRd

# Optional per-host overrides (replace dots in the IP with underscores):
#   SONIC_HOST_10_46_11_50_USERNAME=admin
#   SONIC_HOST_10_46_11_50_PASSWORD=somethingelse

# ------------------------------------------------------------------
# Transport tunables
# ------------------------------------------------------------------

# RESTCONF (mgmt-framework) over HTTPS
SONIC_RESTCONF_PORT=443
SONIC_VERIFY_TLS=false
SONIC_RESTCONF_TIMEOUT_SECONDS=20

# SSH (paramiko)
SONIC_SSH_TIMEOUT_SECONDS=20

# ------------------------------------------------------------------
# MCP server tunables
# ------------------------------------------------------------------

MCP_LOG_LEVEL=INFO
MCP_MAX_BODY_SIZE=1048576
MCP_RATE_LIMIT_RPM=60

# Comma-separated CORS origins, or "*" for any. Empty = no cross-origin requests.
CORS_ORIGINS=

# ------------------------------------------------------------------
# Mutations kill switch (MUTATION / DESTRUCTIVE policy tier)
# ------------------------------------------------------------------
# 0 = all write tools rejected with HTTP 403 (safe default)
# 1 = write tools allowed; per-tool requires_confirmation still applies.
MCP_MUTATIONS_ENABLED=0

# Optional: override mutation ledger path. Default: logs/mutations.jsonl
# MCP_MUTATION_LEDGER=logs/mutations.jsonl
